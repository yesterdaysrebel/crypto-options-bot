BOT_MODE=dry
BOT_LOG_LEVEL=INFO
BOT_DATA_DIR=./data
BOT_REPORTS_DIR=./reports
BOT_JOURNALS_DIR=./journals
BOT_LOGS_DIR=./logs

DELTA_BASE_URL=https://api.india.delta.exchange
DELTA_WS_URL=wss://socket.india.delta.exchange
DELTA_API_KEY=
DELTA_API_SECRET=

BOT_NAV_INR=50000
BOT_USD_INR_RATE=85.0

# Desk gates (IV/OI/greeks/portfolio) live in config/global.yaml under `desk:` — keep enabled: false until dry-run tuning.

DELTA_REST_RPS=10
DELTA_ORDER_RPS=5
DELTA_WS_MPS=20

# Writable path; prod Docker mounts ./runtime. For bare-metal + node_exporter, point here instead:
# PROM_TEXTFILE_PATH=/var/lib/node_exporter/textfile_collector/bot.prom
PROM_TEXTFILE_PATH=./runtime/metrics/bot.prom
PROM_HTTP_PORT=9091
# In Docker use 0.0.0.0 (compose sets this); bare-metal local dev can keep 127.0.0.1.
# PROM_HTTP_HOST=0.0.0.0

BACKBLAZE_B2_KEY=
BACKBLAZE_B2_SECRET=
BACKBLAZE_B2_BUCKET=
